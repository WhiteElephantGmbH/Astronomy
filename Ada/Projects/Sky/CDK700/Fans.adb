pragma Style_White_Elephant;

with Parameter;
with PWI.Fans;

package body Fans is

  procedure Turn_On_Or_Off is
  begin
    if Parameter.Turn_Fans_On then
      if not PWI.Fans.Turned_On then
        PWI.Fans.Turn_On;
      end if;
    else
      if PWI.Fans.Turned_On then
        PWI.Fans.Turn_Off;
      end if;
    end if;
  end Turn_On_Or_Off;

end Fans;
